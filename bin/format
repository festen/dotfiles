#!/usr/bin/env zsh
source "$(dirname $0)/pipeable"

# functions
help() {
    cat <<EOL
Usage: $0 [-h] [-o <format>] <datetime>
Formats the given datetime to the given datetime

<format> can either be 'short', 'long' or a format string as described in gdate

When no <format> is chosen, the output defaults to 'long'
EOL
}

extractParts() {
    d=$(($td/86400))
    h=$((($td-$d*86400)/3600))
    m=$((($td-$d*86400-$h*3600)/60))
    s=$(($td-$d*86400-$h*3600-$m*60))
}

concat() {
    local d=$1; shift
    echo -n "$1"; shift
    printf "%s" "${@/#/$d}"
}

long() {
    parts=()
    extractParts "$@"
    if [ "$d" -eq 1 ]; then
        echo "$d day"
        return 0
    elif [ "$d" -gt 1 ]; then
        echo "$d days"
        return 0
    fi

    if [ "$h" -eq 1 ]; then
        parts+="$h hour"
    elif [ "$h" -gt 1 ]; then
        parts+="$h hours"
    fi
    if [ "$m" -eq 1 ]; then
        parts+="$m minute"
    elif [ "$m" -gt 1 ]; then
        parts+="$m minutes"
    fi
    if [ "$h" -eq 0 ]; then
        test "$tms" -ne 0 && sms="$s.$tms" || sms="$s"
        if [ "$s" -eq 1 ]; then
            parts+="$sms second"
        elif [ "$s" -gt 1 ]; then
            parts+="$sms seconds"
        fi
    fi
    concat ', ' $parts
    echo ''
}

short() {
    extractParts "$@"
    if [ "$td" -gt 86400 ]; then
        echo "${d}d ${h}h${m}m"
    elif [ "$td" -gt 3600 ]; then
        printf "%d:%02d:%02d\n" $h $m $s
    elif [ "$td" -gt 60 ]; then
        echo $m\'$s\"$tms
    else
        echo $s\"$tms
    fi
}
# read the options
input=%s.%N
output=long
case "$1" in
    -o) output="$2"; shift 2;;
    -h) help; exit 1;;
esac
t=$(date -ud @${1:-0} +${input})
td=$(printf %d $t)
tms=$(printf %d $((($t-$td)*100)) )


if [ "$output" = 'short' ]; then
    short $t
elif [ "$output" = 'long' ]; then
    long $t
else
    date -u -d @$t +$output
fi
