#!/usr/bin/env zsh
version=1.0.1

# variables
name=$(basename $0)
speed=0.3
default=spinner

# functions
i-dots() { while kill -0 "$child_pid" 2>/dev/null; do sleep $speed; printf .; done }
i-spinner() {
    chars='\|/-'
    speed=$(eval "python -c 'print $speed/${#chars}.0'")
    i=0
    printf ' '
    while kill -0 "$child_pid" 2>/dev/null; do
        i=$(( (i+1) % ${#chars} ))
        printf '\b'
        printf " ${chars:$i:1}"
        printf '\b'
        sleep $speed
    done
}
-help() {
    cat <<EOF
Usage: $name [OPTION] <cmd>
Displays an indicator while running command
Example: $name -t dots sleep 5

  -h, --help            Displays this help text.
  -s, --silent          Do not print output of running command
      --speed=SPEED     Adjust animation speed [default: $speed].
  -t, --type=TYPE       Type of indicator to use [default: $default].
                        TYPE is on of the following: spinner, dots.
  -v, --version         Displays version number.
EOF
}
-error() {
    err='Unknown error'
    case "$1" in
        args) err="Missing argument for $2";;
        no_command) err='No command given';;
        unknown_indicator) err="Unknown progress indicator: $2";;
    esac
    echo ${RED}Error: $err${RESET_COLOR}; -help; exit 1
}
-is-indicator() {
    type "i-$1" | grep -q 'shell function'
}

# check flags
indicator=$default
while [ "${1:0:1}" = '-' ]; do
    case "$1" in
        -h|--help) -help; exit 0;;
        -v|--version) echo $version; exit 0;;
        -s|--silent) silent=true; shift;;
        --speed) speed="$1"; shift;;
        -t|--type)
            test -z "$2" && -error args "$1"
            -is-indicator "$2" || -error unknown_indicator "$2"
            indicator="$2"
            shift 2;;
    esac
done

test ${#@} -eq 0 && -error no_command

if [ "$silent" = 'true' ]; then
    eval "$@" >/dev/null 2>&1 &
else
    eval "$@" &
fi
child_pid=$!
eval "i-$indicator"
