#!/usr/bin/env zsh

CODE="$HOME/code"
PDIR="$CODE/$1"
PROJECT="$1"
PROGRAM="$(basename $0)"
FMT="$RESET$BOLD$PROJECT$RESET"
STARTS=("$PDIR/.bin/start" "$PDIR/bin/start")

help() {
    echo "Usage: $PROGRAM [project]"
    echo ""
    echo "Known projects:"
    for p in $CODE/*; do
        echo "  $(basename $p)"
    done
    exit 0
}

test -z "$1" && help

for start in $STARTS; do
    if [ -x $start ]; then
        echo "Starting project $FMT"
        cd $PDIR && eval $start && exit 0
    fi
done

if [ -d $PDIR ]; then
    test $+commands[idea] && idea $PDIR || open $PDIR
elif [ -n "$PROJECT" ]; then
    echo "${RED}Project $FMT$RED not found."
else
    help
fi
