#!/usr/bin/env zsh

set -e

for cmd in {boxprint,indicator,vagrant,timer,format}; do
    test $+commands[$cmd] || (echo "missing command: $cmd" && exit 1)
done

cmd() {
    boxprint -t info $2
    indicator "($1 >/dev/null 2>&1)"
    boxprint -ot success $3
}

cd "$HOME/code/mc/web"
clear
timer set
echo "Building M&C webshop v$(cat $HOME/code/mc/version)"

cmd 'vagrant up' 'Checking Vagrant' 'Vagrant up'
cmd 'gulp dev' 'Compiling' 'Compiled'
cmd 'vagrant rsync' 'Syncing' 'Synced'
cmd "vagrant ssh -c 'sudo chmod -R 777 /var/www/api/{tmp,logs,uploads}'" 'Updating permissions' 'Permissions updated'

echo "All done in $(timer get | format)!"
tput bel