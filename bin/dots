#!/usr/bin/env zsh
#
# dots --help           help file
# dots install          (re)installs dotfiles and programs
# dots upgrade          upgrades dotfiles and programs
#

# check if desktop (Darwin, macOS) or server (Linux)
-is-desktop() { test "$(uname)" = 'Darwin'; return $?; }

# variables
name=$(basename $0)
DOTS=$HOME/dots
BIN=$HOME/bin
PATH=$BIN:$DOTS/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
repo='git@github.com:festen/dotfiles'
repo_guest='https://github.com/festen/dotfiles' # credentialess repo
linkignore='.git|.csync_journal*|.owncloudsync|zcompdump*|zdata*|history|antigen|antigen.sh|iterm.sh'
requested_shell=/bin/zsh
sink=$(mktemp)
packagelist="$HOME/packagelist"

# dependent variables
if -is-desktop; then logfile=$HOME/Library/Logs/dotfiles; else logfile=$HOME/log/dotfiles; fi
mkdir -p $(dirname $logfile)
if ! -is-desktop; then touch $packagelist; fi


# shortcuts
alias -g NOOP="> /dev/null 2>&1"
alias -g NO2="2> /dev/null"
if [ -f "$BIN/boxprint" ]; then
    alias puts="$BIN/boxprint"
    alias puti="$BIN/boxprint --type=info"
    alias putw="$BIN/boxprint --type=warn"
    alias putf="$BIN/boxprint --type=fail"
else
    puts(){ echo $@; }
    puti(){ echo $@; }
    putw(){ echo $@; }
    putd(){ echo $@; }
fi

# Functions
dots-install() {
    -initialize
    -install
    -verify
    -cleanup
}
dots-sync() {
    cd $DOTS
    git pull origin master
    git add .
    git commit -m 'Updated dotfiles'
    git push -u origin master
}
dots-update() {
    dots-sync
    if -is-desktop; then
        brew update
        brew bundle check --global && echo 'Packages already up to date' || brew bundle --global
    else
        sudo apt update
        sudo apt upgrade -yq
    fi
}
log() {
    -is-desktop && echo $1 | logger -t 'dotupdater'
    echo $1 >> $logfile
}
help() {
    echo "Usage: $name <command>"
    echo 'Updates the dotfiles and runs package managers'
    echo
    echo "Commands:"
    echo "  (i)nstall:           Installs the dotfiles"
    echo "  (u)pdate:            Updates the dotfiles and brew packages"
    echo "  (s)ync:              Will pull/push latest version of dotfiles"
    echo "  git <git-command>    Executes raw git command (shortcuts: gd: diff, gst: status)"
}
-initialize() {
    log "Starting @ $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    cd $HOME
    -verify-shell
    -ask-password
    -ensure-dotfiles
    -is-desktop && -link-icloud
    -link-folder $(basename $DOTS)
    -link-folder 'var'
    source $HOME/.exports
    source $HOME/.aliases
    source $HOME/.functions
}
-ask-password() {
    sudo -v
    while true; do sudo -n true; sleep 20; kill -0 "$$" || exit; done NO2 &
    clear
    tput sc
}
-link-icloud() {
    puti 'Linking icloud'; ln -fs Library/Mobile\ Documents/com~apple~CloudDocs icloud; puts -o 'Linked icloud'
    puti 'Linking .env'; ln -fs icloud/.env; puts -o 'Linked .env'
    -link-folder '.env'
}
-ensure-dotfiles() {
    printf 'Searching for existing dotfiles... '
    mkdir -p $CLOUD
    test -d $DOTS && echo 'found' && return
    printf 'dotfiles not found!\nDownloading dotfiles... '
    rm -rf $DOTS NOOP
    if ! $(which git NOOP); then echo 'Could not download dotfiles, please install git first'; fi
    git clone $repo_guest $DOTS
    test $? -eq 0 && echo 'done' || (echo 'failed!'; exit 1)
    (cd $DOTS && git remote remove origin && git remote add origin $repo) NOOP
}
-link-folder() {
    puti "Linking $1 content"
    for x in $(/usr/bin/find "./$1" -mindepth 1 -maxdepth 1 | xargs -I{} basename {} | egrep -vw "$linkignore"); do
        rm -rf "$(basename $x)" NOOP
        ln -fs "$1/$(basename $x)" NOOP
    done
    puts -o "Linked $1 content"
    # TODO logging | log "$(echo "$src $dst" | sed -e 's:/Users/david/::g' | sed -e 's:stack/dots:$DOTS:g' | xargs -n2 printf '  Link: %-25s -> %s')"
}
-install() {
    if -is-desktop; then
        -install-homebrew
        -install-homebrew-packages
    else
        -install-apt-packages
    fi
}
-install-homebrew() {
    puti "Verifying Homebrew installation"
    if ! brew --version NOOP; then
        put --type=warn "Homebrew not found, now installing Homebrew"
        log '  Brew: installing'
        /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/uninstall)"<<<y NOOP
        /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"<<<\n NOOP
        log '  Brew: installed'
    fi
    puts -o "Homebrew installed and updated"
}
-install-homebrew-packages() {
    puti "Checking packages"
    log '  Brew: upgrading'
    brew upgrade 2>/dev/null | tr -s "\n" | tee >(logger -t 'dotupdater') >(xargs -I {} echo '  ├── {}' | tr -s "\n" >> $logfile) | /usr/bin/tr -u "\n" "\0" | xargs -0n1 putw -o "Updating packages - " 2>/dev/null
    log '  Brew: upgraded'
    log '  Brew: running bundle'
    brew bundle --global 2>/dev/null | tee >(logger -t 'dotupdater') >(xargs -I {} echo '  ├── {}' | tr -s "\n" | sed -e 's/├── Success/└── Success/' >> $logfile) | /usr/bin/tr -u "\n" "\0" | xargs -0n1 putw -o "Installing packages - " 2>/dev/null
    log '  Brew: bundle ran'
    puts -o "Packages installed and updated"
}
-install-apt-packages() {
    if which apt NOOP; then
        sudo apt update
        sudo apt upgrade -fy
        xargs -a <(awk '/^\s*[^#]/' "$packagelist") -r -- sudo apt install
    else
        putf "Could not find apt"
    fi
}
-verify() {
    -verify-shell
    -verify-permissions
    -verify-rc
}
-verify-shell() {
    puti "Checking shell"
    if [ "$SHELL" = "$requested_shell" ]; then
        puts -o "Shell is $requested_shell"
    elif [ -n "$pass" ]; then
        chsh -s $requested_shell
        puts -o "Shell set to $requested_shell"
        log "  Shell: set to $requested_shell"
    else
        putf -o "Shell is $SHELL instead of $requested_shell."
        putf "please change manually."
        exit 1
    fi
}
-verify-permissions() {
    puti "Checking file permissions"
    chmod 755 $HOME/bin/*(N) NOOP
    log "  Permissions: ~/bin/* -> 755"
    chmod 644 $HOME/.ssh/{config,known_hosts} NOOP
    log "  Permissions: ~/.ssh/{config,known_hosts} -> 644"
    chmod 444 $HOME/.ssh/*.pub(N) NOOP
    log "  Permissions: ~/.ssh/*.pub -> 444"
    chmod 400 $HOME/.ssh/*.key(N) NOOP
    log "  Permissions: ~/.ssh/*.key -> 400"
    puts -o "File permissions checked"
}
-verify-rc() {
    puti 'Sourcing .zshrc/antigen'
    source $HOME/.zshrc NOOP
    puts -o 'Sourced .zshrc/antigen'
}
-cleanup() {
    -cleanup-broken-links
    if ! -is-desktop; then sudo apt autoremove; fi
    puti "Cleaning up leftovers"
    rm -f $sink NOOP
    sudo cleanup NOOP
    puts -o "Cleaned up"
}
-cleanup-broken-links() {
    puti 'Removing broken links'
    find -L {/usr/local/bin,/Applications,$HOME,$HOME/Applications}(N) -maxdepth 1 -name -prune -o -type l -exec rm -rf {} +
    test $? -eq 0 && puts -o 'Removed broken links' || putf -o "Removing broken links failed"
}

case "$1" in
    -h|--help) help; exit;;
    gst|status) (cd $DOTS && git status); exit;;
    gd|diff) shift 1; (cd $DOTS && git diff); exit;;
    git) shift 1; (cd $DOTS && git $@); exit;;
    i*) dots-install;;
    u*) dots-update "$2";;
    s*) dots-sync; exit;;
    *) help; exit;;
esac
