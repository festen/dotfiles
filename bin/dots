#!/usr/bin/env zsh
#
# dots --help           help file
# dots install          (re)installs dotfiles, brews, casks
# dots upgrade          upgrades dotfiles
# dots upgrade --full   upgrades dotfiles, brews, casks
#

name=$(basename $0)
DOTS=$HOME/dots
ENV=$HOME/env
BIN=$HOME/bin
PATH=$BIN:$DOTS/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
repo='git@github.com:festen/dotfiles'
repo_guest='https://github.com/festen/dotfiles' # credentialess repo
logfile=$HOME/Library/Logs/festen.update
linkignore='.git|.csync_journal*|.owncloudsync|zcompdump*|zdata*|history|antigen|antigen.sh|iterm.sh'
requested_shell=/bin/zsh

# shortcuts
alias -g NOOP="> /dev/null 2>&1"
alias -g NO2="2> /dev/null"
put="$BIN/boxprint"
alias put="$put -o"
alias puti="$put --type=info"

# Functions
dots-install() {
    -before
    -install
    -verify
    -cleanup
}
dots-sync() {
    cd $DOTS
    git pull origin master
    git add .
    git commit -m 'Updated dotfiles'
    git push -u origin master
}
dots-upgrade() {
    dots-sync
    if [ "$1" = '--full' ]; then
        brew update
        brew bundle --global
        brew bundle check --global
    fi
}
log() {
    [ "$(uname)" = 'Darwin' ] && echo $1 | logger -t 'dotupdater'
    echo $1 >> $logfile
}
help() {
    echo "Usage: $name {install,upgrade} [--full]"
    echo 'Updates the dotfiles and runs package managers'
    echo
    echo "  (i)nstall:  When using install, will install all dependencies."
    echo "  (u)pgrade:  When using upgrade, will check for dotfile upgrades"
    echo "                Optionally, the --full flag can be passed, this script"
    echo "                will then also verify and upgrade package managers"
    echo "  (s)ync:     Will pull/push latest version"
    echo "  git:        Execute raw git command (shortcuts: gd: diff, gst: status)"
}
-before() {
    sudo -v
    while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
    clear
    tput sc
    -ensure-dotfiles
    [ "$(pwd)" = "$HOME" ] || cd $HOME
    log "Starting @ $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
    $BIN/timer set $timefile
    -link-folder $(basename $DOTS)
    -link-folder 'var'
    -link-folder '.env'
    source $HOME/.exports
}
-ensure-dotfiles() {
    printf 'Searching for existing dotfiles... '
    mkdir -p $CLOUD
    test -d $DOTS && echo 'found' && return
    printf 'dotfiles not found!\nDownloading dotfiles... '
    rm -rf $DOTS NOOP
    git clone $repo_guest $DOTS
    test $? -eq 0 && echo 'done' || (echo 'failed!'; exit 1)
    (cd $DOTS && git remote remove origin && git remote add origin $repo) NOOP
}
-link-folder() {
    puti "Linking $1"
    for x in $(/usr/bin/find "$1/" -depth 1 | xargs -I{} basename {} | egrep -vw "$linkignore"); do
        cd ~
        rm -rf "$(basename $x)"
        ln -fs "$1/$(basename $x)"
    done
    put "Linked $1"
    # TODO logging | log "$(echo "$src $dst" | sed -e 's:/Users/david/::g' | sed -e 's:stack/dots:$DOTS:g' | xargs -n2 printf '  Link: %-25s -> %s')"
}
-install() {
    [ "$(uname)" = 'Darwin' ] || return 0
    -install-homebrew
    -install-packages
    -install-antigen
}
-install-homebrew() {
    puti "Verifying Homebrew installation"
    if ! brew --version NOOP; then
        put --type=warn "Homebrew not found, now installing Homebrew"
        log '  Brew: installing'
        /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/uninstall)"<<<y NOOP
        /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"<<<\n NOOP
        log '  Brew: installed'
    fi
    put "Homebrew installed and updated"
}
-install-packages() {
    puti "Checking packages"
    log '  Brew: upgrading'
    brew upgrade 2>/dev/null | tr -s "\n" | tee >(logger -t 'dotupdater') >(xargs -I {} echo '  ├── {}' | tr -s "\n" >> $logfile) | /usr/bin/tr -u "\n" "\0" | xargs -0n1 $put -o --type=warn "Updating packages - " 2>/dev/null
    log '  Brew: upgraded'
    log '  Brew: running bundle'
    brew bundle --global 2>/dev/null | tee >(logger -t 'dotupdater') >(xargs -I {} echo '  ├── {}' | tr -s "\n" | sed -e 's/├── Success/└── Success/' >> $logfile) | /usr/bin/tr -u "\n" "\0" | xargs -0n1 $put -o --type=warn "Installing packages - " 2>/dev/null
    log '  Brew: bundle ran'
    put "Packages installed and updated"
}
-install-antigen() {
    puti "Checking antigen"
    curl -L https://raw.githubusercontent.com/zsh-users/antigen/master/antigen.zsh > $CLOUD/var/antigen.sh 2>/dev/null
    put "Antigen installed and updated"
}
-verify() {
    -verify-shell
    -verify-permissions
    -verify-rc
}
-verify-shell() {
    puti "Checking shell"
    if [ "$SHELL" = "$requested_shell" ]; then
        put "Shell is $requested_shell"
    elif [ -n "$pass" ]; then
        sudo -S chsh -s $requested_shell david <<< $pass NOOP
        put "Shell set to $requested_shell"
        log "  Shell: set to $requested_shell"
    else
        put --type=fail "Shell is $SHELL instead of $requested_shell."
        puti '' # needed to NOT overwrite previous line
        put --type=fail "No sudo pass provided so please change manually."
    fi
}
-verify-permissions() {
    puti "Checking file permissions"
    chmod 755 $HOME/bin/*(N) NOOP
    log "  Permissions: ~/bin/* -> 755"
    chmod 644 $HOME/.ssh/{config,known_hosts}
    log "  Permissions: ~/.ssh/{config,known_hosts} -> 644"
    chmod 444 $HOME/.ssh/*.pub(N) NOOP
    log "  Permissions: ~/.ssh/*.pub -> 444"
    chmod 400 $HOME/.ssh/*.key(N) NOOP
    log "  Permissions: ~/.ssh/*.key -> 400"
    put "File permissions checked"
}
-verify-rc() {
    puti 'Sourcing .zshrc/antigen'
    source $HOME/.zshrc NOOP
    put 'Sourced .zshrc/antigen'
}
-cleanup() {
    -cleanup-broken-links
    puti "Cleaning up leftovers"
    source $HOME/.functions
    cleanup
    put "Cleaned up"
}
-cleanup-broken-links() {
    puti 'Removing broken links'
    find -L {/usr/local/bin,/Applications,$HOME,$HOME/Applications}(N) -maxdepth 1 -name -prune -o -type l -exec rm -rf {} +
    test $? -eq 0 && put 'Removed broken links' || put --type=fail "Removing broken links failed"
}
-rm-brew() {
    if [ "$(uname)" = 'Darwin' ]; then
        puti 'Uninstalling Homebrew'
        ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/uninstall)" <<< y NOOP
        rm -rf /usr/local/bin/brew /usr/local/Cellar /opt/hombrew-cask
        test $? -eq 0 && put 'Uninstalled Homebrew' || put --type=fail "Uninstalling Homebrew failed"
    fi
}
-rm-npm() {
    if $(which npm NOOP); then
        puti 'Uninstalling NPM'
        rm -rf /usr/local/{lib/node{,/.npm,_modules},bin,share/man}/npm* NOOP
        rm -rf /usr/local/lib/node_modules NOOP
        test $? -eq 0 && put 'Uninstalled NPM' || put --type=fail 'Uninstalling NPM failed'
    fi
}

case "$1" in
    -h|--help) help; exit;;
    gst|status) (cd $DOTS && git status); exit;;
    gd|diff) shift 1; (cd $DOTS && git diff); exit;;
    git) shift 1; (cd $DOTS && git $@); exit;;
    i*) dots-install;;
    u*) dots-upgrade "$2";;
    s*) dots-sync; exit;;
    *) help; exit;;
esac
